# =============================================================
# Saigon Rider - Dev Environment Config (EXAMPLE)
# Copy this file to .env and fill in your values
# =============================================================

# Network
NETWORK_BRIDGE=saigon-net

# Ports
NGINX_PORT=18090
FRONTEND_PORT=5174
BACKEND_PORT=8082
DB_PORT=5435

# Database (PostgreSQL + PostGIS)
DB_NAME=saigon_rider
DB_USER=saigon
DB_PASSWORD=change_me

# Frontend → API base URL
VITE_USE_MOCK=true
VITE_API_BASE=http://localhost:18090/api

# Imgproxy
# KEY/SALT 미설정 시 /insecure/ 경로 사용 가능 (개발 전용)
# 운영 시: openssl rand -hex 32
IMGPROXY_KEY=
IMGPROXY_SALT=

# ── Engine 서비스 ──────────────────────────────────────────
ENGINE_PORT=8090
# BFF→Engine 서비스 인증 키 (운영 시: openssl rand -hex 32)
ENGINE_SERVICE_KEY=change_me_engine_service_key
ENGINE_ADMIN_JWT_SECRET=change_me_engine_admin_jwt_secret

# ── Wiki Basic Auth ────────────────────────────────────────
# /wiki/docs/private/ 접근 시 Nginx Basic Auth에 사용
WIKI_AUTH_USER=admin
WIKI_AUTH_PASS=changeme

# ── SRE 비즈니스 룰 (docker-compose에서 직접 주입되므로 참고용) ──
# SRE_TIMEZONE=Asia/Ho_Chi_Minh
# SRE_RP_EXPIRY_MONTHS=3
# SRE_DAILY_CAP_STANDARD=250
# SRE_DAILY_CAP_DRIVER=2000
# SRE_NEW_ACCOUNT_PENALTY_DAYS=3
# SRE_NEW_ACCOUNT_MULTIPLIER=0.5
# SRE_IDEMPOTENCY_TTL_DAYS=7
# SRE_LOG_LEVEL=INFO
