# =============================================================
# Saigon Rider - Dev Environment Config (EXAMPLE)
# Copy this file to .env and fill in your values
# =============================================================

# Network
NETWORK_BRIDGE=saigon-net

# Ports
NGINX_PORT=18090
FRONTEND_PORT=5174
BACKEND_PORT=8082
DB_PORT=5435

# Database (PostgreSQL + PostGIS)
DB_NAME=saigon_rider
DB_USER=saigon
DB_PASSWORD=change_me

# Frontend → API base URL
VITE_USE_MOCK=true
VITE_API_BASE=http://localhost:18090/api

# Imgproxy
# KEY/SALT 미설정 시 /insecure/ 경로 사용 가능 (개발 전용)
# 운영 시: openssl rand -hex 32
IMGPROXY_KEY=
IMGPROXY_SALT=
