# =============================================================
# Saigon Rider - Dev Environment Config (EXAMPLE)
# Copy this file to .env and fill in your values
# =============================================================

# Network
NETWORK_BRIDGE=dev-net

# Ports
NGINX_PORT=18090
FRONTEND_PORT=5174
BACKEND_PORT=8082
DB_PORT=5435

# Database (PostgreSQL + PostGIS)
DB_NAME=saigon_rider
DB_USER=saigon
DB_PASSWORD=change_me

# Frontend → API base URL
VITE_API_BASE_URL=http://localhost:18090/api
