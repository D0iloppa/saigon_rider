# =============================================================
# Saigon Rider - Dev Environment Config (EXAMPLE)
# Copy this file to .env and fill in your values
# =============================================================

# Network
NETWORK_BRIDGE=saigon-net

# Ports
NGINX_PORT=18090
FRONTEND_PORT=5174
BACKEND_PORT=8082
DB_PORT=5435

# Database (PostgreSQL + PostGIS)
DB_NAME=saigon_rider
DB_USER=saigon
DB_PASSWORD=change_me

# Frontend → API base URL
VITE_USE_MOCK=true
VITE_API_BASE=http://localhost:18090/api

# ── BFF ────────────────────────────────────────────────────
# BFF 공개 URL (절대경로 redirect, mock-img endpoint 등에 사용)
BFF_PUBLIC_URL=http://localhost:18090
# BFF 타임존 (DAILY/WEEKLY 퀘스트 일자 경계, 월별 통계 등)
APP_TIMEZONE=Asia/Seoul

# Imgproxy
# KEY/SALT 미설정 시 /insecure/ 경로 사용 가능 (개발 전용)
# 운영 시: openssl rand -hex 32
IMGPROXY_KEY=
IMGPROXY_SALT=
# 클라이언트에 반환할 imgproxy 공개 URL
IMGPROXY_BASE_URL=http://localhost:18090/img

# ── Redis (Message Queue) ─────────────────────────────────
# Docker 내부 네트워크 전용 (포트 미노출)
REDIS_URL=redis://redis:6379/0
REDIS_FUEL_PRICE_PREFIX=saigon:fuel:

# ── Engine 서비스 ──────────────────────────────────────────
ENGINE_PORT=8090
# BFF→Engine 서비스 인증 키 (운영 시: openssl rand -hex 32)
ENGINE_SERVICE_KEY=change_me_engine_service_key
ENGINE_ADMIN_JWT_SECRET=change_me_engine_admin_jwt_secret
# Engine 워커가 BFF 내부 API 콜백 시 사용 (Docker 내부 호스트)
BFF_INTERNAL_URL=http://bff:8080

# ── Plane (프로젝트 관리) ──────────────────────────────────
PLANE_API_KEY=
PLANE_URL=https://plane.doil.me
PLANE_WORKSPACE=doil
PLANE_PROJECT_ID=

# ── MCP Dev Server (legacy — Plane으로 대체됨) ─────────
MCP_DEV_PORT=8095

# ── Admin Console (Backend 어드민) ─────────────────────────
# 운영 시: ADMIN_PASS_HASH 는 passlib bcrypt 해시, JWT_SECRET 은 openssl rand -hex 32
# ADMIN_USER / ADMIN_PASS_HASH 는 root 관리자 (비밀번호 분실 방지용 정적 계정).
# 일반 관리자 계정은 admin_accounts 테이블에서 root 가 등록.
ADMIN_USER=change_me_admin_user
ADMIN_PASS_HASH=change_me_admin_pass_hash
ADMIN_JWT_SECRET=change_me_admin_jwt_secret

# Wiki 링크 (admin 콘솔 → 위키 메뉴 / login 화면 하단). nginx /wiki/ 프록시 경로.
WIKI_BASE_PATH=/wiki/

# ── Wiki Basic Auth ────────────────────────────────────────
# /wiki/docs/private/ 접근 시 Nginx Basic Auth에 사용
WIKI_AUTH_USER=admin
WIKI_AUTH_PASS=changeme

# ── Info Modules (날씨·침수·주유소·정비소) ──────────────────────
# OpenWeather API (https://openweathermap.org/api) — Free tier: 60 calls/min
OPENWEATHER_API_KEY=
# RainViewer API (https://www.rainviewer.com/api.html)
RAINVIEWER_API_KEY=
# OSM Overpass endpoint (공개 인스턴스 그대로 사용 가능)
OSM_OVERPASS_ENDPOINT=https://overpass-api.de/api/interpreter
# Google Maps Directions API (주유소/정비소 경로 미리보기 — SGR-269)
# 비우면 [경로] 진입 시 "준비 중" 안내(폴백). 키 입력 시 즉시 실경로 활성화.
GOOGLE_MAPS_API_KEY=
# 캐시 TTL (초)
WEATHER_CACHE_TTL_CURRENT=600
WEATHER_CACHE_TTL_FORECAST_1H=1800
WEATHER_CACHE_TTL_FORECAST_24H=3600

# ── SRE 비즈니스 룰 (docker-compose에서 직접 주입되므로 참고용) ──
# SRE_TIMEZONE=Asia/Ho_Chi_Minh
# SRE_XP_EXPIRY_MONTHS=3
# SRE_DAILY_CAP_STANDARD=250
# SRE_DAILY_CAP_DRIVER=2000
# SRE_NEW_ACCOUNT_PENALTY_DAYS=3
# SRE_NEW_ACCOUNT_MULTIPLIER=0.5
# SRE_IDEMPOTENCY_TTL_DAYS=7
# SRE_LOG_LEVEL=INFO

# ── Firebase Cloud Messaging (FCM) ──────────────────────────────
# 서비스 계정 JSON 파일 경로 (Docker 내부 경로)
# engine/ 디렉토리 내에 서비스 계정 JSON 파일 배치 (./engine:/app 마운트로 자동 접근)
FIREBASE_CREDENTIALS_JSON=/app/firebase-credentials.json
# 푸시 발송 이력 Redis TTL (일)
FCM_PUSH_HISTORY_TTL_DAYS=7

# ── Google AI Studio (Imagen 이미지 생성용) ────────────────────────
# scripts/generate_quest_card_images.py 등 이미지 생성 스크립트에서 사용
# AI Studio (https://aistudio.google.com/) 에서 발급한 API 키 (AIza...)
GOOGLE_API_KEY=
