# =============================================================
# Environment & Secrets
# =============================================================
.env
*.local

# =============================================================
# Docker volumes / generated data
# =============================================================
database/data/

# =============================================================
# Frontend (Vue 3 + Vite + Node)
# =============================================================
frontend/node_modules/
frontend/dist/
frontend/.vite/
frontend/*.local

# =============================================================
# Backend (Spring Boot / Maven)
# =============================================================
backend/target/
backend/.mvn/wrapper/maven-wrapper.jar
backend/*.class

# Gradle (if switched later)
backend/.gradle/
backend/build/
backend/out/

# =============================================================
# IDE & OS
# =============================================================
.idea/
*.iml
.vscode/
*.swp
*.swo
.DS_Store
Thumbs.db

# =============================================================
# Logs
# =============================================================
*.log
logs/

# =============================================================
# Capacitor (mobile build outputs)
# =============================================================
frontend/android/
frontend/ios/
frontend/.capacitor/

# =============================================================
# Contents - 유저 업로드 파일 (폴더 구조만 유지)
# =============================================================
contents/user-contents/*
!contents/user-contents/.gitkeep
